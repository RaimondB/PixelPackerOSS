    <path android:pathData="M83,29 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M11,65 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M83,65 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M11,83 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M29,83 h14 v14 h-14 z" android:fillColor="#0f1828"/>
