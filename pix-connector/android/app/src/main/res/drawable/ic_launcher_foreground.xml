    <path android:pathData="M83,83 h14 v14 h-14 z" android:fillColor="#0f1828"/>

    <!-- ── Orange glow halos (20×20, centered behind each orange LED) ──── -->
    <path android:pathData="M44,8  h20 v20 h-20 z" android:fillColor="#40ffa500"/>
    <path android:pathData="M26,26 h20 v20 h-20 z" android:fillColor="#40ffa500"/>
    <path android:pathData="M62,26 h20 v20 h-20 z" android:fillColor="#40ffa500"/>
    <path android:pathData="M8,44  h20 v20 h-20 z" android:fillColor="#40ffa500"/>
    <path android:pathData="M80,44 h20 v20 h-20 z" android:fillColor="#40ffa500"/>
    <path android:pathData="M26,62 h20 v20 h-20 z" android:fillColor="#40ffa500"/>
