<?xml version="1.0" encoding="utf-8"?>
<!--
  LED burst pattern — 5×5 pixel grid.
  Canvas: 108×108 dp (standard adaptive icon foreground size).
  Grid params: cell 14dp, gap 4dp, step 18dp, start 11dp.

  Pattern:
    . . O . .
    . O C O .
    O C C C O
    . O C O .
    . . O . .

  O = orange (#ffa500), C = cyan (#00d4ff), . = off (#0f1828)
-->
