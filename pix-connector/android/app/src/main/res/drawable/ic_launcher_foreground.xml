    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- ── Off LEDs ─────────────────────────────────────────────────────── -->
    <path android:pathData="M11,11 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M29,11 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M65,11 h14 v14 h-14 z" android:fillColor="#0f1828"/>
    <path android:pathData="M83,11 h14 v14 h-14 z" android:fillColor="#0f1828"/>
