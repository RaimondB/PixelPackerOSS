    <path android:pathData="M44,62 h20 v20 h-20 z" android:fillColor="#4000d4ff"/>

    <!-- ── Orange LEDs ────────────────────────────────────────────────── -->
    <path android:pathData="M47,11 h14 v14 h-14 z" android:fillColor="#ffa500"/>
